# ============================================================
# Variáveis de ambiente — AI Like a PRO (Cloudflare Pages)
# ============================================================
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env.
# Configure estas variáveis no painel do Cloudflare Pages:
#   Settings → Environment variables
# ============================================================

# InfinitePay — identificador da conta (handle)
# Padrão atual: 'leveltech'. Sobrescreva aqui se mudar de conta.
INFINITEPAY_HANDLE=leveltech

# Resend — API key para envio de e-mail de notificação de leads
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Google Apps Script — URL do script de integração com Sheets
# Gere via: Apps Script → Deploy → Manage deployments → Web app URL
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/SEU_SCRIPT_ID/exec

# Google Apps Script — Secret compartilhado para autenticar chamadas ao script
# Defina o mesmo valor no Apps Script para validar requests
GOOGLE_SCRIPT_SECRET=seu-secret-aqui

# Webhook — Secret incluído na webhook_url enviada à InfinitePay
# Qualquer string aleatória forte (ex: openssl rand -hex 32)
WEBHOOK_SECRET=seu-webhook-secret-aqui

# URL de redirecionamento pós-pagamento (página de sucesso)
REDIRECT_URL=https://growthclub.pro/success.html
